# =============================================================================
# TenantTracker-Web Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the actual .env file to version control.
# =============================================================================

# --- OAuth 2.0 Provider Configuration ---

# Google OAuth 2.0 (OpenID Connect)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# 1. Create an OAuth 2.0 Client ID (Web application type)
# 2. Add authorized redirect URI: http://localhost:5173/auth/callback/google
# 3. For production, add your production domain's callback URL
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# GitHub OAuth App
# Get credentials from: https://github.com/settings/developers
# 1. Create a new OAuth App
# 2. Set Authorization callback URL: http://localhost:5173/auth/callback/github
# 3. For production, add your production domain's callback URL
VITE_GITHUB_CLIENT_ID=your-github-client-id

# --- OAuth Redirect Configuration ---
# Base URL for OAuth redirect URIs. Defaults to window.location.origin if not set.
# Set this explicitly in production to your domain.
# VITE_OAUTH_REDIRECT_BASE=https://yourdomain.com

# --- API Configuration ---
# Backend API base URL (already configured in src2/config/api.js)
# VITE_API_BASE_URL=http://localhost:5001
